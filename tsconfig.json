{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "adapters/**/*.ts",
    "backend/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "sentinel-web",
    "dist"
  ]
}
